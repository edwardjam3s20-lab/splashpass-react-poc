# Safaricom's Daraja docs are safe to use locally for testing.)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://splashmain.vercel.app/api/mpesa-callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Africa's Talking SMS (server-side only)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SplashPass
AT_MESSAGING_URL=https://api.sandbox.africastalking.com/version1/messaging
VITE_ONESIGNAL_APP_ID=d07fe924-2edc-47d1-99b7-6810fe5824c5

# Supabase (server-side only — the SERVICE ROLE key, never the anon/
# publishable one above. Required by api/mpesa-stk.js and api/send-sms.js
# for the rate-limit RPC and, for mpesa-stk, the booking-ownership check.
# Get both from Supabase dashboard → Project Settings → API.)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of origins allowed to call api/mpesa-stk.js and
# api/send-sms.js. Set this to your real deployed frontend origin(s) —
# it defaults to https://splashmain.vercel.app if unset, which fails
# safe (deny-by-default) rather than open (previously these routes sent
# `Access-Control-Allow-Origin: *` with no check at all).
ALLOWED_ORIGINS=https://splashmain.vercel.app